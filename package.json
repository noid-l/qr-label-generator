{
  "name": "qr-label-generator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "bun run build && npx wrangler pages deploy dist --project-name=qr-label-generator",
    "deploy:prod": "bun run build && npx wrangler pages deploy dist --project-name=qr-label-generator --branch=production"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "jszip": "^3.10.1",
    "pinia": "^3.0.4",
    "qrcode.vue": "^3.4.1",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "vite": "8.0.3",
    "vue-tsc": "^3.1.5"
  }
}
